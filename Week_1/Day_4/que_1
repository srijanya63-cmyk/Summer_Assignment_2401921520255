Matrix Diagonal Sum
class Solution {
    public int diagonalSum(int[][] mat) {
        int n = mat.length;
        int total = 0;

        for (int i = 0; i < n; i++) {
            total += mat[i][i];
            total += mat[i][n - i - 1];
        }

        if (n % 2 != 0) {
            total -= mat[n / 2][n / 2];
        }

        return total;
    }
}